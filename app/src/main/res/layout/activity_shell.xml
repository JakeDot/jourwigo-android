<?xml version="1.0" encoding="utf-8"?>
<!--
    Shell activity layout — four tabs: JavaScript · Lua · Termux · Shizuku
    The output pane at the bottom is shared across all tabs.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TabHost
        android:id="@+id/tab_host"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TabWidget
                android:id="@android:id/tabs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <FrameLayout
                android:id="@android:id/tabcontent"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- ── JavaScript tab ── -->
                <LinearLayout
                    android:id="@+id/tab_js"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <EditText
                        android:id="@+id/et_js_input"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:fontFamily="monospace"
                        android:gravity="top|start"
                        android:hint="@string/hint_js"
                        android:inputType="textMultiLine|textNoSuggestions"
                        android:scrollbars="vertical" />

                    <Button
                        android:id="@+id/btn_run_js"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_run" />
                </LinearLayout>

                <!-- ── Lua tab ── -->
                <LinearLayout
                    android:id="@+id/tab_lua"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <EditText
                        android:id="@+id/et_lua_input"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:fontFamily="monospace"
                        android:gravity="top|start"
                        android:hint="@string/hint_lua"
                        android:inputType="textMultiLine|textNoSuggestions"
                        android:scrollbars="vertical" />

                    <Button
                        android:id="@+id/btn_run_lua"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_run" />
                </LinearLayout>

                <!-- ── Termux tab ── -->
                <LinearLayout
                    android:id="@+id/tab_termux"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <EditText
                        android:id="@+id/et_termux_input"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:fontFamily="monospace"
                        android:gravity="top|start"
                        android:hint="@string/hint_termux"
                        android:inputType="textMultiLine|textNoSuggestions"
                        android:scrollbars="vertical" />

                    <Button
                        android:id="@+id/btn_run_termux"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_send_termux" />
                </LinearLayout>

                <!-- ── Shizuku tab ── -->
                <LinearLayout
                    android:id="@+id/tab_shizuku"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <EditText
                        android:id="@+id/et_shizuku_input"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:fontFamily="monospace"
                        android:gravity="top|start"
                        android:hint="@string/hint_shizuku"
                        android:inputType="textMultiLine|textNoSuggestions"
                        android:scrollbars="vertical" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btn_shizuku_request"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/btn_request_shizuku" />

                        <Button
                            android:id="@+id/btn_run_shizuku"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/btn_run" />
                    </LinearLayout>
                </LinearLayout>

            </FrameLayout>
        </LinearLayout>
    </TabHost>

    <!-- ── Shared output pane ── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutline" />

    <TextView
        android:id="@+id/tv_output"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="#111111"
        android:fontFamily="monospace"
        android:padding="8dp"
        android:scrollbars="vertical"
        android:textColor="#00FF41"
        android:textSize="12sp" />

    <Button
        android:id="@+id/btn_clear_output"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_clear" />

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.jourwigo.mobile">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.JourwigoMobile">
        
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- cgeo plugin integration: Geocache details -->
            <intent-filter>
                <action android:name="cgeo.geocaching.intent.action.GEOCACHE_DETAILS" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="cgeo" android:host="geocache" />
            </intent-filter>

            <!-- cgeo plugin integration: Context menu -->
            <intent-filter>
                <action android:name="cgeo.geocaching.intent.action.GEOCACHE_CONTEXT_MENU" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <meta-data android:name="cgeo.geocaching.plugin.api.version" android:value="1" />
    </application>

</manifest>
